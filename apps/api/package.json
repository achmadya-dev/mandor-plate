{
  "name": "@mandor-plate/api",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "typeorm": "env-cmd -- node -r ts-node/register/transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "pnpm run typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d src/database/data-source.ts",
    "seed:run": "ts-node -r tsconfig-paths/register ./src/database/seeds/relational/run-seed.ts",
    "prebuild": "pnpm --filter @mandor-plate/shared build && rimraf dist",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "pretypecheck": "pnpm --filter @mandor-plate/shared build",
    "test": "jest --passWithNoTests",
    "test:e2e": "env-cmd -- jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1011.0",
    "@aws-sdk/s3-request-presigner": "3.1011.0",
    "@mandor-plate/shared": "workspace:*",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "@types/multer-s3": "3.0.3",
    "apple-signin-auth": "2.0.0",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.3.1",
    "google-auth-library": "10.6.2",
    "handlebars": "4.7.9",
    "helmet": "^8.2.0",
    "ms": "2.1.3",
    "multer": "2.1.1",
    "multer-s3": "3.0.1",
    "nodemailer": "8.0.2",
    "passport": "0.7.0",
    "passport-anonymous": "1.0.1",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "source-map-support": "0.5.21",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.28",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@nestjs/cli": "11.0.18",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.18",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/ms": "2.1.0",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "@types/passport-anonymous": "1.0.5",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "env-cmd": "11.0.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "^17.4.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=20"
  }
}
